{
  "name": "game-parser-bot",
  "version": "1.0.0",
  "description": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node ./dist/app.js",
    "start:prod": "npm run migration:run && npm run start",
    "dev": "ts-node-dev ./app.ts",
    "test": "jest",
    "typeorm": "ts-node --project tsconfig.json -r tsconfig-paths/register ./node_modules/.bin/typeorm -d ./src/config/typeOrm.config.ts",
    "migration:generate": "npm run typeorm -- migration:generate ./src/migrations/migration",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "ts-jest": "^29.4.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "dotenv": "^17.3.1",
    "jsdom": "^29.1.1",
    "pg": "^8.18.0",
    "reflect-metadata": "^0.2.2",
    "telegraf": "^4.16.3",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^1.0.0"
  }
}
